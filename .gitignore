# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...except the template, which documents the variables and holds no secrets
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Claude Code toolkit (skills, agents, hooks) — personal setup, not part
# of the app. settings.local.json in particular holds machine-specific paths.
.claude/

# local data store
/data/

# file ke hoach ca nhan, khong commit
timeline-roadmap.html
lich-roadmap.csv
.~lock.*#
