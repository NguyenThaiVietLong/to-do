# Copy to .env.local and fill in.

# Postgres connection string. Neon's free plan is enough for this app:
# https://neon.com → create a project → copy the connection string.
DATABASE_URL=

# The single shared password for the whole app.
#
# Leave it unset in development and the app runs open, with no login screen.
# A production build refuses to serve at all without it, so that an
# unauthenticated read/write API is never exposed by accident.
APP_PASSWORD=
