# The single shared password for the whole app. Copy this file to .env.local
# and set a value.
#
# Leave it unset in development and the app runs open, with no login screen.
# A production build refuses to serve at all without it, so that an
# unauthenticated read/write API is never exposed by accident.
APP_PASSWORD=

# Where db.json is written. Defaults to ./data — set this to the mount path of
# a persistent volume when deploying.
# DATA_DIR=/data
